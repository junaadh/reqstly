# Reqstly Embedded Auth Stack (local development template)
# Copy to `.env.local` (or run `./scripts/setup-dev.sh`).

# Domains and public URLs
APP_DOMAIN=localhost
API_DOMAIN=api.localhost
APP_URL=https://localhost
API_URL=https://api.localhost
CADDY_ACME_EMAIL=devnull@localhost

# Compose / runtime basics
COMPOSE_PROJECT_NAME=reqstly
SMOKE_INSECURE_TLS=true
BACKEND_IMAGE=reqstly-backend
BACKEND_IMAGE_TAG=local
FRONTEND_IMAGE=reqstly-frontend
FRONTEND_IMAGE_TAG=local

# Database
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432
TEST_DATABASE_PORT=54323
POSTGRES_PASSWORD=replace-with-generated-postgres-password

# Backend auth/session config
AUTH__WS_TOKEN_SECRET=replace-with-generated-ws-token-secret
AUTH__WS_TOKEN_ISSUER=reqstly.local/ws
AUTH__SESSION_COOKIE_NAME=reqstly_session
AUTH__SESSION_IDLE_MINUTES=480
AUTH__SESSION_SECURE=false
AUTH__WEBAUTHN_RP_ID=localhost
AUTH__WEBAUTHN_RP_ORIGIN=https://localhost
AUTH__WEBAUTHN_RP_NAME="Reqstly Local"

# Backend app config
SERVER__PORT=3000
SERVER__BASE_URL=https://api.localhost
CORS__ALLOWED_ORIGIN=https://localhost
RUST_LOG=info
LOGGING__LEVEL=reqstly_backend=info,tower_http=info,axum=info
LOGGING__FORMAT=json
LOGGING__SERVICE_NAME=reqstly-backend
LOGGING__ENVIRONMENT=dev
BACKEND_HEALTH_START_PERIOD=120s

# Frontend runtime
PUBLIC_API_BASE_URL=https://api.localhost
PRIVATE_API_BASE_URL=http://backend:3000
ORIGIN=https://localhost
CHOKIDAR_USE_POLLING=false
CHOKIDAR_INTERVAL=1000
VITE_USE_POLLING=false
VITE_POLLING_INTERVAL=1000

# Observability
PROMETHEUS_PORT=9090
LOKI_PORT=3100
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-generated-grafana-password
