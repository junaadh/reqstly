      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "id": 8,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "expr": "{compose_service=\"backend\"} |= \"ERROR\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent Backend Error Logs",
      "type": "logs"
