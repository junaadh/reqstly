# Reqstly + Supabase Full Stack (local development template)
# Copy to `.env.local` (or run `./scripts/setup-dev.sh` to generate automatically).

# Domains and public URLs
APP_DOMAIN=localhost
API_DOMAIN=api.localhost
SUPABASE_DOMAIN=supabase.localhost
APP_URL=https://localhost
API_URL=https://api.localhost
SUPABASE_PUBLIC_URL=https://supabase.localhost
API_EXTERNAL_URL=https://supabase.localhost
SITE_URL=https://localhost
ADDITIONAL_REDIRECT_URLS=https://localhost,https://api.localhost,https://supabase.localhost
CADDY_ACME_EMAIL=devnull@localhost

# Reqstly app runtime
RUST_LOG=info
RP_ID=localhost
ORIGIN=https://localhost
SMOKE_INSECURE_TLS=true
COMPOSE_PROJECT_NAME=reqstly
LOGGING__LEVEL=reqstly_backend=info,tower_http=info,axum=info
LOGGING__FORMAT=json
LOGGING__SERVICE_NAME=reqstly-backend
LOGGING__ENVIRONMENT=dev
BACKEND_HEALTH_START_PERIOD=600s
BACKEND_IMAGE=reqstly-backend
BACKEND_IMAGE_TAG=local
FRONTEND_IMAGE=reqstly-frontend
FRONTEND_IMAGE_TAG=local

# Observability
PROMETHEUS_PORT=9090
LOKI_PORT=3100
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Supabase secrets (setup script replaces these with generated values)
POSTGRES_PASSWORD=replace-with-generated-postgres-password
JWT_SECRET=replace-with-generated-jwt-secret
ANON_KEY=replace-with-generated-anon-key
SERVICE_ROLE_KEY=replace-with-generated-service-role-key
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=replace-with-generated-dashboard-password
SECRET_KEY_BASE=replace-with-generated-secret-key-base
VAULT_ENC_KEY=replace-with-generated-vault-enc-key
PG_META_CRYPTO_KEY=replace-with-generated-pg-meta-crypto-key
LOGFLARE_PUBLIC_ACCESS_TOKEN=replace-with-generated-logflare-public-token
LOGFLARE_PRIVATE_ACCESS_TOKEN=replace-with-generated-logflare-private-token
S3_PROTOCOL_ACCESS_KEY_ID=replace-with-generated-s3-access-key-id
S3_PROTOCOL_ACCESS_KEY_SECRET=replace-with-generated-s3-access-key-secret

# Database and pooler
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=54322
TEST_DATABASE_PORT=54323
POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_TENANT_ID=reqstly-dev
POOLER_DB_POOL_SIZE=5

# Studio
STUDIO_DEFAULT_ORGANIZATION=ReqstlyLocal
STUDIO_DEFAULT_PROJECT=ReqstlyDev
OPENAI_API_KEY=

# Auth
JWT_EXPIRY=3600
DISABLE_SIGNUP=false
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=reqstly-local
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=true
ENABLE_PHONE_AUTOCONFIRM=true
MFA_ENABLED=true
MFA_WEBAUTHN_ENABLED=true
MFA_WEBAUTHN_ENROLL_ENABLED=true
MFA_WEBAUTHN_VERIFY_ENABLED=true
MFA_WEB_AUTHN_ENABLED=true
MFA_WEB_AUTHN_ENROLL_ENABLED=true
MFA_WEB_AUTHN_VERIFY_ENABLED=true

# Storage and functions
GLOBAL_S3_BUCKET=stub
REGION=stub
MINIO_ROOT_USER=supa-storage
MINIO_ROOT_PASSWORD=replace-with-generated-minio-password
STORAGE_TENANT_ID=stub
FUNCTIONS_VERIFY_JWT=false

# API and analytics
PGRST_DB_SCHEMAS=public,storage,graphql_public
DOCKER_SOCKET_LOCATION=/var/run/docker.sock
GOOGLE_PROJECT_ID=GOOGLE_PROJECT_ID
GOOGLE_PROJECT_NUMBER=GOOGLE_PROJECT_NUMBER

# Kong and imgproxy
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
IMGPROXY_ENABLE_WEBP_DETECTION=true

# Optional Supabase proxy variables
PROXY_DOMAIN=supabase.localhost
CERTBOT_EMAIL=devnull@localhost
