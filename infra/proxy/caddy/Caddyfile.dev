{
	admin off
}

https://api.localhost {
	tls /etc/caddy/certs/dev/reqstly-dev.crt /etc/caddy/certs/dev/reqstly-dev.key
	reverse_proxy backend:3000

	log {
		output file /dev/stdout
		format console
	}
}

https://supabase.localhost {
	tls /etc/caddy/certs/dev/reqstly-dev.crt /etc/caddy/certs/dev/reqstly-dev.key

	handle /health {
		header {
			X-Service "supabase-gateway"
			Content-Type application/json
		}
		respond `{"status":"ok","service":"supabase-gateway"}` 200
	}

	handle {
		reverse_proxy kong:8000
	}

	log {
		output file /dev/stdout
		format console
	}
}

https://localhost {
	tls /etc/caddy/certs/dev/reqstly-dev.crt /etc/caddy/certs/dev/reqstly-dev.key
	handle /health {
		header {
			X-Service "caddy"
			Content-Type application/json
		}
		respond `{"status":"ok","service":"caddy"}` 200
	}

	@backend_ws {
		path /ws /ws/*
	}

	handle @backend_ws {
		reverse_proxy backend:3000
	}

	handle {
		reverse_proxy frontend:3000
	}

	log {
		output file /dev/stdout
		format console
	}
}
