# Reqstly + Supabase Full Stack (production-oriented template)

# Domains and public URLs
APP_DOMAIN=reqstly.com
API_DOMAIN=api.reqstly.com
SUPABASE_DOMAIN=supabase.reqstly.com
APP_URL=https://reqstly.com
API_URL=https://api.reqstly.com
SUPABASE_PUBLIC_URL=https://supabase.reqstly.com
API_EXTERNAL_URL=https://supabase.reqstly.com
SITE_URL=https://reqstly.com
ADDITIONAL_REDIRECT_URLS=https://reqstly.com,https://api.reqstly.com,https://supabase.reqstly.com
CADDY_ACME_EMAIL=ops@reqstly.com

# Reqstly app runtime
RUST_LOG=info
RP_ID=reqstly.com
ORIGIN=https://reqstly.com
SMOKE_INSECURE_TLS=false
COMPOSE_PROJECT_NAME=reqstly
LOGGING__LEVEL=reqstly_backend=info,tower_http=info,axum=info
LOGGING__FORMAT=json
LOGGING__SERVICE_NAME=reqstly-backend
LOGGING__ENVIRONMENT=production
BACKEND_HEALTH_START_PERIOD=120s
BACKEND_IMAGE=reqstly-backend
BACKEND_IMAGE_TAG=local

# Supabase secrets
POSTGRES_PASSWORD=replace-with-strong-postgres-password
JWT_SECRET=replace-with-strong-jwt-secret-32-plus-chars
ANON_KEY=replace-with-generated-anon-jwt
SERVICE_ROLE_KEY=replace-with-generated-service-role-jwt
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=replace-with-strong-dashboard-password
SECRET_KEY_BASE=replace-with-strong-secret-key-base
VAULT_ENC_KEY=replace-with-32-char-vault-enc-key
PG_META_CRYPTO_KEY=replace-with-strong-pg-meta-key
LOGFLARE_PUBLIC_ACCESS_TOKEN=replace-with-logflare-public-token
LOGFLARE_PRIVATE_ACCESS_TOKEN=replace-with-logflare-private-token
S3_PROTOCOL_ACCESS_KEY_ID=replace-with-s3-access-key-id
S3_PROTOCOL_ACCESS_KEY_SECRET=replace-with-s3-access-key-secret

# Database and pooler
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432
TEST_DATABASE_PORT=54323
POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_TENANT_ID=reqstly-prod
POOLER_DB_POOL_SIZE=5

# Studio
STUDIO_DEFAULT_ORGANIZATION=Reqstly
STUDIO_DEFAULT_PROJECT=ReqstlyProduction
OPENAI_API_KEY=

# Auth
JWT_EXPIRY=3600
DISABLE_SIGNUP=false
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
SMTP_ADMIN_EMAIL=admin@reqstly.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=reqstly
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=true
ENABLE_PHONE_AUTOCONFIRM=true

# Storage and functions
GLOBAL_S3_BUCKET=stub
REGION=stub
MINIO_ROOT_USER=supa-storage
MINIO_ROOT_PASSWORD=replace-with-minio-password
STORAGE_TENANT_ID=stub
FUNCTIONS_VERIFY_JWT=false

# API and analytics
PGRST_DB_SCHEMAS=public,storage,graphql_public
DOCKER_SOCKET_LOCATION=/var/run/docker.sock
GOOGLE_PROJECT_ID=GOOGLE_PROJECT_ID
GOOGLE_PROJECT_NUMBER=GOOGLE_PROJECT_NUMBER

# Kong and imgproxy
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
IMGPROXY_ENABLE_WEBP_DETECTION=true

# Optional Supabase proxy variables
PROXY_DOMAIN=supabase.reqstly.com
CERTBOT_EMAIL=ops@reqstly.com
