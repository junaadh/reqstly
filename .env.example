# Reqstly Embedded Auth Stack (production-oriented template)

# Domains and public URLs
APP_DOMAIN=reqstly.com
API_DOMAIN=api.reqstly.com
APP_URL=https://reqstly.com
API_URL=https://api.reqstly.com
PRIVATE_API_BASE_URL=http://backend:3000
CADDY_ACME_EMAIL=ops@reqstly.com

# Compose / runtime basics
COMPOSE_PROJECT_NAME=reqstly
SMOKE_INSECURE_TLS=false
BACKEND_IMAGE=reqstly-backend
BACKEND_IMAGE_TAG=local
FRONTEND_IMAGE=reqstly-frontend
FRONTEND_IMAGE_TAG=local

# Database
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432
TEST_DATABASE_PORT=54323
POSTGRES_PASSWORD=replace-with-strong-postgres-password
# URL-encoded form of POSTGRES_PASSWORD for DSN-style URLs.
POSTGRES_PASSWORD_ENCODED=replace-with-url-encoded-postgres-password

# Backend auth/session config
AUTH__WS_TOKEN_SECRET=replace-with-strong-ws-token-secret
AUTH__WS_TOKEN_ISSUER=reqstly.com/ws
AUTH__SESSION_COOKIE_NAME=reqstly_session
AUTH__SESSION_IDLE_MINUTES=480
AUTH__SESSION_SECURE=true
AUTH__WEBAUTHN_RP_ID=reqstly.com
AUTH__WEBAUTHN_RP_ORIGIN=https://reqstly.com
AUTH__WEBAUTHN_RP_NAME=Reqstly

# Backend app config
SERVER__PORT=3000
SERVER__BASE_URL=https://api.reqstly.com
CORS__ALLOWED_ORIGIN=https://reqstly.com
RUST_LOG=info
LOGGING__LEVEL=reqstly_backend=info,tower_http=info,axum=info
LOGGING__FORMAT=json
LOGGING__SERVICE_NAME=reqstly-backend
LOGGING__ENVIRONMENT=production
BACKEND_HEALTH_START_PERIOD=120s

# Frontend runtime
PUBLIC_API_BASE_URL=https://api.reqstly.com
ORIGIN=https://reqstly.com

# Observability
PROMETHEUS_PORT=9090
LOKI_PORT=3100
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-strong-grafana-password
